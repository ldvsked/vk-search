# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vk_search
POSTGRES_USER=vk_user
POSTGRES_PASSWORD=vk_password

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=vk_chunks

# VK API
VK_TOKEN=put_vk_token_here
VK_API_VERSION=5.199
VK_PUBLICS=habr,vkedu,techinsider
VK_TARGET_POSTS=500
VK_REQUEST_SLEEP_SECONDS=0.35

# LLM
LLM_API_KEY=put_llm_key_here
LLM_MODEL=gpt-4o-mini

# Backend
JWT_SECRET=change_me
SERVER_PORT=8080