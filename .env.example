# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5445
POSTGRES_DB=vk_search
POSTGRES_USER=vk_user
POSTGRES_PASSWORD=vk_password

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=vk_chunks

# VK API
VK_TOKEN=put_vk_token_here
VK_API_VERSION=5.199
VK_PUBLICS=history_woman,historyrossia,historydata,politvostok,sportsmed,doc_med
VK_TARGET_POSTS=1500
VK_REQUEST_SLEEP_SECONDS=0.35

# LLM (Бесплатный OpenRouter)
LLM_ENABLED=true
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your_free_openrouter_api_key_here
LLM_MODEL=meta-llama/llama-3-8b-instruct:free
LLM_TIMEOUT_SECONDS=40
LLM_MAX_CONTEXT_CHARS=12000

# Backend
JWT_SECRET=change_me
SERVER_PORT=8080